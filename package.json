{
  "name": "tradingview2claude-connector",
  "version": "1.0.0",
  "description": "TradingView2Claude Connector — Analisi AI del mercato in tempo reale",
  "author": "TradingView2Claude",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.tv2claude.connector",
    "productName": "TradingView2Claude Connector",
    "copyright": "TradingView2Claude Connector",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64"]
        },
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "artifactName": "TradingView2Claude-${arch}.dmg"
    },
    "dmg": {
      "title": "TradingView2Claude Connector"
    },
    "extraResources": [
      {
        "from": "bundled-mcp",
        "to": "bundled-mcp"
      },
      {
        "from": "bundled-node",
        "to": "bundled-node"
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
